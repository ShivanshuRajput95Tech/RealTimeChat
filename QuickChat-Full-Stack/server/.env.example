# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Security - IMPORTANT: Generate a secure random string for production
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
REDIS_URL=redis://localhost:6379

# Cloudinary (File uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_SECURE=true

# AI Configuration
# Options:
# - OpenAI: OPENAI_API_KEY=sk-... AI_BASE_URL=https://api.openai.com/v1
# - Groq (Fast, affordable): OPENAI_API_KEY=gsk_... AI_BASE_URL=https://api.groq.com/openai/v1
# - Ollama (Local): OPENAI_API_KEY=ollama AI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=your-ai-api-key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_DAILY_LIMIT=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
